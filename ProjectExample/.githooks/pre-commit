#!/bin/sh
#
# pre-commit hook: secret scanning + lint staged Python files with ruff
#

# --- Secret scanning ---
# Scans all staged text files for common secret patterns
SECRETS_FOUND=0
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)

if [ -n "$STAGED_ALL" ]; then
    for FILE in $STAGED_ALL; do
        # Skip binary files and .env (already gitignored, but just in case)
        if file "$FILE" 2>/dev/null | grep -q "text"; then
            if git show ":$FILE" 2>/dev/null | grep -qEi \
                '(sk-[a-zA-Z0-9]{20,}|ANTHROPIC_API_KEY|OPENAI_API_KEY|MISTRAL_API_KEY|password\s*=\s*["'"'"'][^"'"'"']+|api_key\s*=\s*["'"'"'][^"'"'"']+|BEGIN (RSA |DSA |EC )?PRIVATE KEY)'; then
                echo "WARNING: Possible secret in $FILE"
                SECRETS_FOUND=1
            fi
        fi
    done
fi

if [ $SECRETS_FOUND -ne 0 ]; then
    echo ""
    echo "Commit blocked: potential secrets detected in staged files."
    echo "Review the files above. If intentional, use --no-verify (not recommended)."
    exit 1
fi

# --- Python linting ---
# Find staged .py files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$')

if [ -z "$STAGED_PY" ]; then
    exit 0
fi

# Check if ruff is available
if command -v ruff >/dev/null 2>&1; then
    RUFF_CMD="ruff"
elif command -v uv >/dev/null 2>&1; then
    RUFF_CMD="uv run ruff"
else
    echo "Warning: ruff not found. Skipping Python lint check."
    echo "Install with: uv add --dev ruff"
    exit 0
fi

echo "Running ruff on staged .py files..."

# Lint staged files
FAILED=0
for FILE in $STAGED_PY; do
    # Check the staged version, not the working copy
    git show ":$FILE" | $RUFF_CMD check --stdin-filename "$FILE" -
    if [ $? -ne 0 ]; then
        FAILED=1
    fi
done

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "Commit blocked: fix ruff errors above, then re-stage and commit."
    echo "To auto-fix: ruff check --fix <file>"
    exit 1
fi
